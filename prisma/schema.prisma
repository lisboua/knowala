// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  username      String    @unique
  password      String? // null for Google OAuth users
  image         String?
  googleId        String?   @unique
  emailVerified   Boolean   @default(false)
  needsOnboarding Boolean   @default(false)
  hasSeenWelcome  Boolean   @default(false)
  role          Role      @default(USER)
  ecoScore      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invitesRemaining        Int       @default(0)
  emailDigest             Boolean   @default(true)
  emailDigestToken        String?   @unique
  emailWeeklyDigest       Boolean   @default(true)
  emailWeeklyDigestToken  String?   @unique

  answers            Answer[]
  comments           Comment[]
  votesGiven         Vote[]
  reportsGiven       Report[]
  badges             UserBadge[]
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  suggestions        Suggestion[]
  suggestionVotes    SuggestionVote[]
  inviteCodesCreated InviteCode[] @relation("InviteCodesCreated")
  inviteCodeUsed     InviteCode?  @relation("InviteCodeUsed")
  notifications      Notification[] @relation("NotificationRecipient")
  actorNotifications Notification[] @relation("NotificationActor")
  bookmarks          Bookmark[]
}

enum Role {
  USER
  ADMIN
}

model Question {
  id           String         @id @default(cuid())
  content      String
  slug         String?        @unique
  publishedAt  DateTime?
  scheduledFor DateTime?
  status       QuestionStatus @default(DRAFT)
  createdAt    DateTime       @default(now())

  answers   Answer[]
  bookmarks Bookmark[]
}

enum QuestionStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

model Answer {
  id           String    @id @default(cuid())
  content      String
  userId       String
  questionId   String
  deletedByMod Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  editedAt     DateTime?

  user     User      @relation(fields: [userId], references: [id])
  question Question  @relation(fields: [questionId], references: [id])
  comments  Comment[]
  votes     Vote[]     @relation("VoteAnswer")
  reports   Report[]   @relation("ReportAnswer")
  bookmarks Bookmark[]

  @@unique([userId, questionId])
}

model Comment {
  id           String    @id @default(cuid())
  content      String
  userId       String
  answerId     String
  parentId     String? // for nested comments
  deletedByMod Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  editedAt     DateTime?

  user    User      @relation(fields: [userId], references: [id])
  answer  Answer    @relation(fields: [answerId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
  votes     Vote[]     @relation("VoteComment")
  reports   Report[]   @relation("ReportComment")
  bookmarks Bookmark[]
}

// Unified vote model - uses separate FK columns for answer and comment
model Vote {
  id         String     @id @default(cuid())
  userId     String
  targetType VoteTarget
  value      Int // +1 or -1
  answerId   String?
  commentId  String?
  createdAt  DateTime   @default(now())

  user    User     @relation(fields: [userId], references: [id])
  answer  Answer?  @relation("VoteAnswer", fields: [answerId], references: [id])
  comment Comment? @relation("VoteComment", fields: [commentId], references: [id])

  @@unique([userId, answerId, targetType])
  @@unique([userId, commentId, targetType])
}

enum VoteTarget {
  ANSWER
  COMMENT
}

// Unified report model - uses separate FK columns for answer, comment, and suggestion
model Report {
  id           String       @id @default(cuid())
  userId       String
  targetType   ReportTarget
  reason       String
  status       ReportStatus @default(PENDING)
  answerId     String?
  commentId    String?
  suggestionId String?
  createdAt    DateTime     @default(now())

  user       User        @relation(fields: [userId], references: [id])
  answer     Answer?     @relation("ReportAnswer", fields: [answerId], references: [id])
  comment    Comment?    @relation("ReportComment", fields: [commentId], references: [id])
  suggestion Suggestion? @relation("ReportSuggestion", fields: [suggestionId], references: [id])

  @@unique([userId, answerId, targetType])
  @@unique([userId, commentId, targetType])
  @@unique([userId, suggestionId, targetType])
}

enum ReportTarget {
  ANSWER
  COMMENT
  SUGGESTION
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model Badge {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  description String
  icon        String

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Suggestion {
  id            String   @id @default(cuid())
  content       String
  userId        String
  deletedByMod  Boolean  @default(false)
  postedByAdmin Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User               @relation(fields: [userId], references: [id])
  votes   SuggestionVote[]
  reports Report[]           @relation("ReportSuggestion")
}

model SuggestionVote {
  id           String   @id @default(cuid())
  userId       String
  suggestionId String
  value        Int      // +1 or -1
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  suggestion Suggestion @relation(fields: [suggestionId], references: [id])

  @@unique([userId, suggestionId])
}

// ===== Notifications =====

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  actorId   String?
  entityId  String?
  meta      Json?
  createdAt DateTime         @default(now())
  expiresAt DateTime

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id])
  actor User? @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([userId, read])
  @@index([expiresAt])
}

enum NotificationType {
  ANSWER_UPVOTE
  ANSWER_COMMENT
  COMMENT_REPLY
  MILESTONE
  BADGE_EARNED
  DAILY_QUESTION
}

// ===== Bookmarks =====

model Bookmark {
  id         String             @id @default(cuid())
  userId     String
  targetType BookmarkTargetType
  questionId String?
  answerId   String?
  commentId  String?
  createdAt  DateTime           @default(now())

  user     User      @relation(fields: [userId], references: [id])
  question Question? @relation(fields: [questionId], references: [id])
  answer   Answer?   @relation(fields: [answerId], references: [id])
  comment  Comment?  @relation(fields: [commentId], references: [id])

  @@unique([userId, questionId, targetType])
  @@unique([userId, answerId, targetType])
  @@unique([userId, commentId, targetType])
}

enum BookmarkTargetType {
  QUESTION
  ANSWER
  COMMENT
}

// ===== Beta / Invite System =====

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model InviteCode {
  id            String    @id @default(cuid())
  code          String    @unique
  createdById   String
  usedById      String?   @unique
  usedAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  createdBy User  @relation("InviteCodesCreated", fields: [createdById], references: [id])
  usedBy    User? @relation("InviteCodeUsed", fields: [usedById], references: [id])
}
